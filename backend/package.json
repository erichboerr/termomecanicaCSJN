{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development dotenv -e .env -- nodemon server.js",
    "start:prod": "cross-env NODE_ENV=production dotenv -e .env.production -- node server.js",
    "db:migrate": "dotenv -e .env.production -- sequelize-cli db:migrate",
    "db:undo": "dotenv -e .env.production -- sequelize-cli db:migrate:undo:all",
    "db:seed": "dotenv -e .env.production -- sequelize-cli db:seed:all"
  },
  "keywords": [],
  "author": "Erich Boerr, erichkboerr@gmail.com",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "bootstrap": "^5.3.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemon": "^3.1.10",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "postgres": "^3.4.7",
    "react-bootstrap": "^2.10.10",
    "sanitize-filename": "^1.6.3",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.3",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.0.0",
    "dotenv-cli": "^10.0.0",
    "sequelize-cli": "^6.6.3"
  }
}
